{
  "$schema": "../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SabbathCue",
  "version": "0.1.8",
  "identifier": "com.bongandlovu.sabbathcue",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "SabbathCue",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' https://www.youtube.com https://www.youtube-nocookie.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://i.ytimg.com; font-src 'self' data:; connect-src 'self' https://gggywgcaldhdtudktfjo.supabase.co; media-src 'self' blob: asset: http://asset.localhost https:; worker-src 'self'; frame-src https://www.youtube-nocookie.com; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'self'; manifest-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**/*.mp4",
          "**/*.webm"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "createUpdaterArtifacts": false,
    "resources": {
      "../data/rhema.db": "rhema.db",
      "../sidecars/vosk_worker.*": "scripts/",
      "../scripts/vosk_worker.py": "scripts/vosk_worker.py",
      "../models/vosk/vosk-model-en-us-0.22-lgraph": "models/vosk/vosk-model-en-us-0.22-lgraph",
      "../models/minilm-l6-v2/tokenizer.json": "models/minilm-l6-v2/tokenizer.json",
      "../models/minilm-l6-v2-int8/onnx/model_quantized.onnx": "models/minilm-l6-v2-int8/onnx/model_quantized.onnx",
      "../embeddings/public-minilm-l6-v2.bin": "embeddings/public-minilm-l6-v2.bin",
      "../embeddings/public-minilm-l6-v2-ids.bin": "embeddings/public-minilm-l6-v2-ids.bin"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEExNEYwMTQyMUVENDM4QTIKUldTaU9OUWVRZ0ZQb1prOGdwUlRGRDhHdG5aMElNcTVMbXlEZXRndkZNZW9ETVBkQTFhTS8zdXMK",
      "endpoints": [
        "https://github.com/bn638260-code/Sabbath/releases/latest/download/latest.json"
      ]
    }
  }
}
