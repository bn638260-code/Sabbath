{
  "name": "sabbathcue",
  "private": true,
  "version": "0.1.7",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "vercel-build": "node scripts/vercel-build.mjs",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc -b",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:build:release": "tauri build --config src-tauri/tauri.release.conf.json",
    "test": "vitest",
    "test:unit": "vitest --run",
    "test:semantic-detections": "vitest --run src/stores/detection-store.semantic-replay.test.ts",
    "test:coverage": "vitest --run --coverage",
    "test:e2e": "node scripts/run-playwright-e2e.mjs",
    "dup": "jscpd",
    "convert:afrikaans-bible": "bun run data/convert-afrikaans-bible.ts",
    "download:bible-data": "bun run data/download-sources.ts",
    "build:bible": "bun run data/build-bible-db.ts",
    "build:egw": "bun run data/build-egw.ts",
    "validate:egw": "bun run data/validate-egw-sources.ts",
    "convert:egw:pp:pdf": "bun run data/convert-egw-pp-pdf.ts",
    "convert:egw:sc:pdf": "bun run data/convert-egw-sc-pdf.ts",
    "convert:egw:da:pdf": "bun run data/convert-egw-da-pdf.ts",
    "convert:egw:ed:pdf": "bun run data/convert-egw-ed-pdf.ts",
    "convert:egw:gc:pdf": "bun run data/convert-egw-gc-pdf.ts",
    "convert:egw:pdf": "bun run convert:egw:pp:pdf && bun run convert:egw:sc:pdf && bun run convert:egw:da:pdf && bun run convert:egw:ed:pdf && bun run convert:egw:gc:pdf",
    "import:egw:pp": "bun run data/import-egw-pp-from-egwwritings.ts",
    "build:bible:public": "bun run convert:afrikaans-bible && cross-env SABBATHCUE_PUBLIC_RELEASE=1 bun run data/build-bible-db.ts",
    "verify:bible:public": "bun run scripts/verify-public-db.ts",
    "verify:windows-installer-download": "node scripts/verify-windows-installer-download.mjs",
    "download:model": "bun run data/download-model.ts",
    "download:multilingual-model": "bun run data/download-multilingual-model.ts",
    "export:verses": "bun run data/compute-embeddings.ts",
    "precompute:embeddings-onnx": "python3 data/precompute-embeddings-onnx.py",
    "precompute:embeddings-py": "python3 data/precompute-embeddings.py",
    "precompute:embeddings": "cargo run --manifest-path src-tauri/Cargo.toml -p rhema-detection --features precompute-bin --release --bin precompute -- --model models/minilm-l6-v2-int8/onnx/model_quantized.onnx --tokenizer models/minilm-l6-v2/tokenizer.json --verses data/verses-for-embedding.json --output-embeddings embeddings/public-minilm-l6-v2.bin --output-ids embeddings/public-minilm-l6-v2-ids.bin",
    "download:vosk": "powershell -ExecutionPolicy Bypass -File scripts/download-vosk-model.ps1",
    "download:whisper": "node data/download-whisper.mjs",
    "build:vosk-sidecar": "powershell -ExecutionPolicy Bypass -File scripts/build-vosk-sidecar.ps1",
    "download:ndi-sdk": "bun run data/download-ndi-sdk.ts",
    "generate:icons": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-app-icons.ps1 && tauri icon public/app-icon.png -o src-tauri/icons",
    "setup:windows": "powershell -ExecutionPolicy Bypass -File scripts/setup-windows.ps1",
    "setup:all": "bun run data/prepare-embeddings.ts",
    "web:dev": "cd web && bun run dev",
    "web:build": "cd web && bun run build",
    "web:start": "cd web && bun run start",
    "web:lint": "cd web && bun run lint"
  },
  "dependencies": {
    "@dnd-kit/react": "^0.3.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/outfit": "^5.2.8",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@fontsource-variable/source-sans-3": "^5.2.9",
    "@fontsource/bebas-neue": "^5.2.7",
    "@fontsource/cinzel": "^5.2.8",
    "@fontsource/dm-mono": "^5.2.7",
    "@fontsource/dm-serif-display": "^5.2.8",
    "@fontsource/playfair-display": "^5.2.8",
    "@supabase/supabase-js": "^2.110.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-dialog": "~2.7.1",
    "@tauri-apps/plugin-global-shortcut": "~2.3.2",
    "@tauri-apps/plugin-log": "~2.8.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@tauri-apps/plugin-store": "~2.4.3",
    "@tauri-apps/plugin-updater": "~2.10.1",
    "@types/bun": "^1.3.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "fabric": "^7.4.0",
    "fuse.js": "^7.4.2",
    "lucide-react": "^1.23.0",
    "radix-ui": "^1.6.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-joyride": "^3.1.0",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "overrides": {
    "@hono/node-server": "2.0.8",
    "brace-expansion": "2.1.1",
    "fast-uri": "4.1.0",
    "hono": "^4.12.25",
    "ip-address": "10.2.0",
    "js-yaml": "5.2.1",
    "path-to-regexp": "8.4.2",
    "picomatch": "4.0.5",
    "qs": "6.15.3",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "4.1.8",
    "bun-types": "^1.3.14",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^16.5.0",
    "jscpd": "^5.0.11",
    "pdfjs-dist": "^5.7.284",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3",
    "vitest": "4.1.8"
  }
}
